{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "content-12",
  "registryDependencies": [
    "@fulldev/accordion",
    "@fulldev/badge",
    "@fulldev/button",
    "@fulldev/icon",
    "@fulldev/section"
  ],
  "files": [
    {
      "path": "src/components/blocks/content-12.astro",
      "content": "---\nimport {\n  Accordion,\n  AccordionContent,\n  AccordionItem,\n  AccordionTrigger,\n} from \"@/components/ui/accordion\"\nimport { Badge } from \"@/components/ui/badge\"\nimport { Button } from \"@/components/ui/button\"\nimport { Icon } from \"@/components/ui/icon\"\nimport {\n  Section,\n  SectionActions,\n  SectionContent,\n  SectionProse,\n  SectionSplit,\n} from \"@/components/ui/section\"\n\ninterface Props {\n  class?: string\n  id?: string\n  links?: {\n    icon?: string\n    text?: string\n    href?: string\n    target?: string\n  }[]\n  items?: {\n    tagline?: string\n    title?: string\n    description?: string\n  }[]\n}\n\nconst { class: className, id, links, items } = Astro.props\n---\n\n<Section class={className} id={id}>\n  <SectionSplit\n    class=\"gap-10 @5xl:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] @5xl:gap-16\"\n  >\n    <SectionContent class=\"max-w-md @5xl:sticky @5xl:top-24 @5xl:self-start\">\n      <SectionProse class=\"max-w-md\">\n        <slot />\n      </SectionProse>\n      <SectionActions>\n        {\n          links?.map(({ icon, text, ...link }, i) => (\n            <Button variant={i === 0 ? \"default\" : \"outline\"} {...link}>\n              {icon && <Icon name={icon} />}\n              {text}\n            </Button>\n          ))\n        }\n      </SectionActions>\n    </SectionContent>\n\n    <Accordion>\n      {\n        items?.map(({ tagline, title, description }, index) => (\n          <AccordionItem>\n            <AccordionTrigger class=\"cursor-pointer items-center gap-4 py-6 text-base font-medium hover:no-underline @md:text-lg\">\n              <div class=\"flex min-w-0 items-center gap-4\">\n                <Badge\n                  variant=\"secondary\"\n                  class=\"bg-foreground text-background group-open/accordion-item:bg-primary group-open/accordion-item:text-primary-foreground size-12 shrink-0 rounded-full border-none px-0 text-sm font-semibold\"\n                >\n                  {tagline || String.fromCharCode(65 + (index % 26))}\n                </Badge>\n                <span class=\"min-w-0 text-balance\">{title}</span>\n              </div>\n            </AccordionTrigger>\n            <AccordionContent class=\"text-muted-foreground pb-6 pl-16 text-base leading-8\">\n              <div class=\"max-w-2xl text-pretty\">{description}</div>\n            </AccordionContent>\n          </AccordionItem>\n        ))\n      }\n    </Accordion>\n  </SectionSplit>\n</Section>\n",
      "type": "registry:block"
    }
  ],
  "type": "registry:block"
}
