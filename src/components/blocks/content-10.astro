---
import { cn } from "@/lib/utils"
import { Badge } from "@/components/ui/badge"
import { Image } from "@/components/ui/image"
import {
  Section,
  SectionActions,
  SectionContent,
  SectionMedia,
  SectionProse,
  SectionSplit,
} from "@/components/ui/section"

interface Props {
  class?: string
  id?: string
  image?: {
    src: string
    alt: string
  }
  items?: {
    title?: string
  }[]
}

const { class: className, id, image, items } = Astro.props
---

<Section class={cn("gap-0 px-0 py-0", className)} id={id} variant="floating">
  <SectionSplit class="gap-0 lg:items-stretch">
    <SectionContent
      class="w-full max-w-xl px-(--section-px) py-(--section-py) lg:self-center"
    >
      <SectionProse>
        <slot />
      </SectionProse>
      <SectionActions>
        {items?.map(({ title }) => <Badge variant="outline">{title}</Badge>)}
      </SectionActions>
    </SectionContent>
    <SectionMedia class="order-first rounded-none">
      <Image sizes="(1536px) 768px, (1024px) 50vw, 100vw" {...image} />
    </SectionMedia>
  </SectionSplit>
</Section>
