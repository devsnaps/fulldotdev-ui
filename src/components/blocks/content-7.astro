---
import { cn } from "@/lib/utils"
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { Icon } from "@/components/ui/icon"
import { Image } from "@/components/ui/image"
import {
  Section,
  SectionActions,
  SectionContent,
  SectionMedia,
  SectionProse,
  SectionSplit,
} from "@/components/ui/section"

interface Props {
  class?: string
  id?: string
  links?: {
    icon?: string
    text?: string
    href?: string
    target?: string
  }[]
  image?: {
    src: string
    alt: string
  }
  items?: {
    icon?: string
    title?: string
  }[]
}

const { class: className, id, links, image, items } = Astro.props
---

<Section class={cn("gap-0 px-0 py-0", className)} id={id} variant="floating">
  <SectionSplit class="gap-0 lg:items-stretch">
    <SectionMedia class="rounded-none">
      <Image sizes="(1536px) 768px, (1024px) 50vw, 100vw" {...image} />
    </SectionMedia>
    <SectionContent
      class="w-full max-w-xl px-(--section-px) py-(--section-py) lg:order-first lg:self-center"
    >
      <SectionProse>
        <slot />
      </SectionProse>
      <SectionActions>
        {
          links?.map(({ icon, text, ...link }, i) => (
            <Button variant={i === 0 ? "default" : "outline"} {...link}>
              {icon && <Icon name={icon} />}
              {text}
            </Button>
          ))
        }
      </SectionActions>
      <SectionActions>
        {
          items?.map(({ icon, title }) => (
            <Badge variant="outline">
              {icon && <Icon name={icon} />}
              {title}
            </Badge>
          ))
        }
      </SectionActions>
    </SectionContent>
  </SectionSplit>
</Section>
