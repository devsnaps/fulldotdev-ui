---
import { cn } from "@/lib/utils"
import { Badge } from "@/components/ui/badge"
import { Image } from "@/components/ui/image"
import { Section, SectionContent, SectionProse } from "@/components/ui/section"
import { Skeleton } from "@/components/ui/skeleton"
import {
  Tile,
  TileActions,
  TileContent,
  TileDescription,
  TileMedia,
  TileSplit,
  TileTitle,
} from "@/components/ui/tile"

interface Props {
  class?: string
  id?: string
  title?: string
  description?: string
  items?: {
    href?: string
    tagline?: string
    title?: string
    description?: string
    list?: string[]
    image?: {
      src: string
      alt: string
    }
  }[]
}

const { class: className, id, items } = Astro.props
---

<Section class={className} id={id}>
  <SectionContent class="gap-y-8">
    <SectionProse>
      <slot />
    </SectionProse>
    {
      items?.map(
        ({ href, tagline, title, description, list, image }, index) => (
          <Tile href={href} variant="floating" class="rounded-xl p-0">
            <TileSplit class="min-h-80 grid-cols-1 gap-0 lg:min-h-105 lg:grid-cols-2">
              <TileContent
                class={cn(
                  "order-2 justify-center gap-5 p-10 lg:p-14",
                  index % 2 === 1 ? "lg:order-2" : "lg:order-1"
                )}
              >
                {tagline && (
                  <TileDescription class="text-lg leading-none">
                    {tagline}
                  </TileDescription>
                )}
                {title && (
                  <TileTitle class="text-4xl tracking-tight">{title}</TileTitle>
                )}
                {description && (
                  <TileDescription class="max-w-md text-base leading-relaxed">
                    {description}
                  </TileDescription>
                )}
                {list?.length && (
                  <TileActions>
                    {list.slice(0, 3).map((entry) => (
                      <Badge
                        variant="outline"
                        class="h-auto rounded-xl px-3 py-1 text-sm"
                      >
                        {entry}
                      </Badge>
                    ))}
                  </TileActions>
                )}
              </TileContent>
              <TileMedia
                class={cn(
                  "order-1 size-full rounded-none",
                  index % 2 === 1 ? "lg:order-1" : "lg:order-2"
                )}
              >
                {image ? (
                  <Image
                    class="size-full object-cover"
                    sizes="(1536px) 768px, (1024px) 50vw, 100vw"
                    {...image}
                  />
                ) : (
                  <Skeleton class="size-full min-h-70 rounded-none" />
                )}
              </TileMedia>
            </TileSplit>
          </Tile>
        )
      )
    }
  </SectionContent>
</Section>
