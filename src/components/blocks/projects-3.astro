---
import { Image } from "@/components/ui/image"
import { Section, SectionContent, SectionProse } from "@/components/ui/section"
import { Skeleton } from "@/components/ui/skeleton"
import {
  Tile,
  TileContent,
  TileDescription,
  TileMedia,
  TileSplit,
  TileTagList,
  TileTitle,
} from "@/components/ui/tile"

interface Props {
  class?: string
  id?: string
  title?: string
  description?: string
  items?: {
    href?: string
    tagline?: string
    title?: string
    description?: string
    list?: string[]
    image?: {
      src: string
      alt: string
    }
  }[]
}

const { class: className, id, items } = Astro.props
---

<Section class={className} id={id}>
  <SectionContent class="gap-y-8">
    <SectionProse>
      <slot />
    </SectionProse>
    {
      items?.map(
        ({ href, tagline, title, description, list, image }, index) => (
          <Tile href={href} variant="floating" class="rounded-xl p-0">
            <TileSplit
              stack="media-first"
              reverse={index % 2 === 0}
              class="min-h-80 grid-cols-1 gap-0 lg:min-h-105 lg:grid-cols-2"
            >
              <TileContent class="justify-center gap-5 p-10 lg:p-14">
                <TileDescription variant="kicker">{tagline}</TileDescription>
                <TileTitle variant="display">{title}</TileTitle>
                <TileDescription variant="lead">{description}</TileDescription>
                <TileTagList items={list} limit={3} variant="pill" />
              </TileContent>
              <TileMedia class="size-full rounded-none">
                {image ? (
                  <Image
                    class="size-full object-cover"
                    sizes="(1536px) 768px, (1024px) 50vw, 100vw"
                    {...image}
                  />
                ) : (
                  <Skeleton class="size-full min-h-70 rounded-none" />
                )}
              </TileMedia>
            </TileSplit>
          </Tile>
        )
      )
    }
  </SectionContent>
</Section>
