---
import type { HTMLAttributes } from "astro/types"
import { cva, type VariantProps } from "class-variance-authority"

import { cn } from "@/lib/utils"

const variants = cva("text-muted-foreground", {
  variants: {
    variant: {
      default: "text-sm",
      eyebrow: "text-primary text-xs font-medium",
      kicker: "text-lg leading-none",
      lead: "max-w-md text-base leading-relaxed",
    },
  },
  defaultVariants: {
    variant: "default",
  },
})

interface Props extends HTMLAttributes<"p">, VariantProps<typeof variants> {}

const { class: className, variant, ...props } = Astro.props
---

<p
  data-slot="tile-description"
  data-variant={variant}
  class={cn(variants({ variant }), className)}
  {...props}
>
  <slot />
</p>
