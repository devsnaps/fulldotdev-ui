---
import type { HTMLAttributes } from "astro/types"
import { cva, type VariantProps } from "class-variance-authority"

import { cn } from "@/lib/utils"

const variants = cva("leading-none font-semibold", {
  variants: {
    variant: {
      default: "",
      display: "text-4xl tracking-tight",
    },
  },
  defaultVariants: {
    variant: "default",
  },
})

interface Props extends HTMLAttributes<"h3">, VariantProps<typeof variants> {}

const { class: className, variant, ...props } = Astro.props
---

<h3
  data-slot="tile-title"
  data-variant={variant}
  class={cn(variants({ variant }), className)}
  {...props}
>
  <slot />
</h3>
